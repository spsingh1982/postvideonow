# ─────────────────────────────────────────
# CLERK — User Authentication
# Get from: https://dashboard.clerk.com → Your App → API Keys
# ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─────────────────────────────────────────
# TIKTOK — Content Posting API
# Get from: https://developers.tiktok.com → Your App → Settings
# ─────────────────────────────────────────
TIKTOK_CLIENT_KEY=REPLACE_ME
TIKTOK_CLIENT_SECRET=REPLACE_ME
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# ─────────────────────────────────────────
# NEON — PostgreSQL Database
# Get from: https://neon.tech → Your Project → Connection Details
# ─────────────────────────────────────────
DATABASE_URL=postgresql://REPLACE_ME@ep-REPLACE_ME.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
